<ui:FluentWindow x:Class="ScreenPulse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="ScreenPulse" Height="680" Width="1470" MinHeight="520" MinWidth="860"
        Icon="pack://application:,,,/Resources/app.ico"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Closing="FluentWindow_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="AppTitleBar" Title="ScreenPulse" Grid.Row="0" />

        <Grid Grid.Row="1" Margin="20,16,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧导航栏 -->
            <Border Grid.Column="0" CornerRadius="8" Padding="6"
                    Background="#14808080" VerticalAlignment="Stretch">
                <StackPanel>
                    <Button x:Name="NavSettingsButton" Height="44" Margin="0,0,0,4"
                            HorizontalContentAlignment="Left" HorizontalAlignment="Stretch"
                            Padding="14,0" FontSize="14" Click="NavSettingsButton_Click"/>
                    <Button x:Name="NavLogButton" Height="44"
                            HorizontalContentAlignment="Left" HorizontalAlignment="Stretch"
                            Padding="14,0" FontSize="14" Click="NavLogButton_Click"/>
                </StackPanel>
            </Border>

            <!-- 右侧内容区 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="PageHeading" Grid.Column="0" FontSize="18" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <ToggleButton x:Name="FilterToggleButton" Grid.Column="1" Padding="12,0" Margin="0,0,8,0"
                                  Click="FilterToggleButton_Click" Visibility="Collapsed"/>
                    <Button x:Name="RefreshButton" Grid.Column="2" Padding="12,0" Margin="0,0,8,0" Click="RefreshLog_Click"
                            Visibility="Collapsed"/>
                    <Button x:Name="ClearLogButton" Grid.Column="3" Padding="12,0" Click="ClearLogButton_Click"
                            Visibility="Collapsed"/>
                </Grid>

                <!-- 设置页 -->
                <ScrollViewer x:Name="SettingsPanel" Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left">

                        <CheckBox x:Name="MonitoringEnabledCheck" Margin="0,0,0,18" Checked="SettingChanged" Unchecked="SettingChanged"/>

                        <Border Background="#0F808080" CornerRadius="8" Padding="16" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock x:Name="IntervalLabelText" Margin="0,0,0,6"/>
                                <TextBox x:Name="IntervalTextBox" Width="120" HorizontalAlignment="Left" Margin="0,0,0,14" LostFocus="SettingChanged"/>

                                <TextBlock x:Name="IdleThresholdLabelText" Margin="0,0,0,6"/>
                                <TextBox x:Name="IdleThresholdTextBox" Width="120" HorizontalAlignment="Left" Margin="0,0,0,14" LostFocus="SettingChanged"/>

                                <CheckBox x:Name="CaptureOnIdleResumeCheck" Margin="0,0,0,14" Checked="SettingChanged" Unchecked="SettingChanged"/>

                                <TextBlock x:Name="RetentionLabelText" Margin="0,0,0,6"/>
                                <TextBox x:Name="RetentionTextBox" Width="120" HorizontalAlignment="Left" Margin="0,0,0,14" LostFocus="SettingChanged"/>

                                <TextBlock x:Name="SimilarityLabelText" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                <TextBox x:Name="SimilarityTextBox" Width="120" HorizontalAlignment="Left" LostFocus="SettingChanged"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#0F808080" CornerRadius="8" Padding="16" Margin="0,0,0,14">
                            <StackPanel>
                                <CheckBox x:Name="AutoStartCheck" Margin="0,0,0,14" Checked="AutoStartChanged" Unchecked="AutoStartChanged"/>

                                <TextBlock x:Name="LanguageLabelText" Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="LangZhRadio" GroupName="Lang" Content="中文" Margin="0,0,16,0" Checked="LanguageChanged"/>
                                    <RadioButton x:Name="LangEnRadio" GroupName="Lang" Content="English" Checked="LanguageChanged"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="#0F808080" CornerRadius="8" Padding="16" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock x:Name="ExcludedLabelText" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                <TextBox x:Name="ExcludedProcessesTextBox" Height="90" AcceptsReturn="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" LostFocus="SettingChanged"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#0F808080" CornerRadius="8" Padding="16">
                            <StackPanel>
                                <TextBlock x:Name="StorageLabelText" Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="StorageFolderText" VerticalAlignment="Center" Margin="0,0,12,0" TextWrapping="Wrap"/>
                                    <Button x:Name="OpenFolderButton" Click="OpenStorageFolder_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- 日志查看页 -->
                <Grid x:Name="LogPanel" Grid.Row="2" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="240"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#0F808080" CornerRadius="8" Padding="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                          Visibility="{Binding Visibility, ElementName=FilterBar}">
                                <StackPanel x:Name="FilterBar" Margin="8,8,8,4" Orientation="Horizontal"
                                            Visibility="Collapsed">
                                    <TextBlock x:Name="FilterFromLabel" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <DatePicker x:Name="FilterFromDate" Width="165" Margin="0,0,6,0" SelectedDateChanged="Filter_Changed"/>
                                    <TextBox x:Name="FilterFromTimeTextBox" Width="64" Margin="0,0,14,0" TextChanged="Filter_Changed"/>

                                    <TextBlock x:Name="FilterToLabel" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <DatePicker x:Name="FilterToDate" Width="165" Margin="0,0,6,0" SelectedDateChanged="Filter_Changed"/>
                                    <TextBox x:Name="FilterToTimeTextBox" Width="64" Margin="0,0,14,0" TextChanged="Filter_Changed"/>

                                    <TextBlock x:Name="FilterProcessLabel" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <ComboBox x:Name="FilterProcessCombo" Width="130" Margin="0,0,14,0" SelectionChanged="Filter_Changed"/>

                                    <TextBlock x:Name="FilterTitleLabel" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBox x:Name="FilterTitleTextBox" Width="140" Margin="0,0,0,0" TextChanged="Filter_Changed"/>
                                </StackPanel>
                            </ScrollViewer>

                            <DataGrid x:Name="LogDataGrid" Grid.Row="1" AutoGenerateColumns="False" Background="Transparent"
                                      BorderThickness="0" IsReadOnly="True"
                                      Sorting="LogDataGrid_Sorting"
                                      SelectionChanged="LogDataGrid_SelectionChanged">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Style.Triggers>
                                            <!-- ShowTimeColumn 同时也是"这一行是不是新的一组时间"的标记,
                                                 排序/筛选后会重新计算,这里顺带复用来画分组分隔线,不需要额外状态 -->
                                            <DataTrigger Binding="{Binding ShowTimeColumn}" Value="True">
                                                <Setter Property="BorderBrush" Value="#4DFFFFFF"/>
                                                <Setter Property="BorderThickness" Value="0,2,0,0"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn x:Name="ColTime" Binding="{Binding TimeColumnText}" Width="130"/>
                                    <DataGridTextColumn x:Name="ColScreen" Binding="{Binding ScreenDisplay}" Width="55"/>
                                    <DataGridTextColumn x:Name="ColProcess" Binding="{Binding ProcessName}" Width="100"/>
                                    <DataGridTextColumn x:Name="ColCpu" Binding="{Binding CpuDisplay}" Width="55"/>
                                    <DataGridTextColumn x:Name="ColMemory" Binding="{Binding MemoryDisplay}" Width="55"/>
                                    <DataGridTextColumn x:Name="ColGpu" Binding="{Binding GpuDisplay}" Width="55"/>
                                    <DataGridTextColumn x:Name="ColNetwork" Binding="{Binding NetworkDisplay}" Width="80"/>
                                    <DataGridTextColumn x:Name="ColTitle" Binding="{Binding WindowTitle}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Background="#0F808080" CornerRadius="8" Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="PreviewList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,12">
                                                <TextBlock Text="{Binding Label}" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                                <Image Source="{Binding Thumbnail}" Stretch="Uniform" HorizontalAlignment="Left"
                                                       MaxHeight="220" Cursor="Hand" Tag="{Binding Path}"
                                                       MouseLeftButtonUp="PreviewThumbnail_Click"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <TextBlock x:Name="PreviewHintText" Grid.Row="1" Margin="0,8,0,0" FontSize="12"
                                       Opacity="0.6" HorizontalAlignment="Center" Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
